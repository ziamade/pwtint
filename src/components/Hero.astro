---
import { site } from '../data/site';
---

<section class="hero" id="hero">
  <div class="hero__blob hero__blob--1" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--2" aria-hidden="true"></div>
  <div class="hero__inner">
    <div class="hero__video-wrap">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source src="/videos/vid_tint.mp4" type="video/mp4" />
      </video>
      <div class="hero__video-overlay"></div>
    </div>

    <div class="hero__content">
      <h1 class="hero__title">
        <span class="hero__title-pacific">Pacific</span>
        <span class="hero__title-wt">Window Tint</span>
      </h1>

      <p class="hero__tagline">
        Stockton's window tinting professionals since {site.foundingYear}.
      </p>

      <p class="hero__description">
        Visit our shop on Davis Road or book a mobile appointment.
        Automotive, residential, and commercial window film.
      </p>

      <div class="hero__actions">
        <a href={`tel:${site.phoneTel}`} class="btn btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {site.phone}
        </a>
        <a href="#contact" class="btn btn--outline">Get a Quote</a>
      </div>

      <div class="hero__meta">
        <div class="hero__open-badge" id="hero-open-badge">
          <span class="hero__open-dot"></span>
          <span class="hero__open-text">Open Now</span>
        </div>
        <a href={site.mapUrl} target="_blank" rel="noopener" class="hero__address">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {site.address}, {site.city}, {site.state}
        </a>
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--color-bg);
    overflow: hidden;
    padding-top: 4.5rem;
  }

  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    pointer-events: none;
    will-change: transform;
  }

  .hero__blob--1 {
    width: 500px;
    height: 500px;
    background: var(--color-accent);
    top: -15%;
    right: -5%;
    animation: blobDrift1 20s ease-in-out infinite;
  }

  .hero__blob--2 {
    width: 350px;
    height: 350px;
    background: var(--color-brand-cyan);
    bottom: -10%;
    left: 10%;
    animation: blobDrift2 25s ease-in-out infinite;
  }

  @keyframes blobDrift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-40px, 30px) scale(1.05); }
    66% { transform: translate(20px, -20px) scale(0.95); }
  }

  @keyframes blobDrift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -25px) scale(1.08); }
    66% { transform: translate(-20px, 15px) scale(0.92); }
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding: 2.5rem var(--section-px) 2rem;
    gap: clamp(2rem, 3vw, 3rem);
  }

  .hero__video-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--color-border);
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 10, 10, 0.15) 0%,
      rgba(10, 10, 10, 0.05) 100%
    );
    pointer-events: none;
  }

  .hero__content {
    padding-block: 0.5rem;
  }

  .hero__title {
    margin-bottom: 1.5rem;
  }

  .hero__title-pacific {
    display: block;
    font-family: var(--font-brand-script);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--color-brand-cyan);
    line-height: 0.9;
    opacity: 0;
    animation: fadeInUp 1s var(--ease-out-expo) 0.3s forwards;
  }

  .hero__title-wt {
    display: block;
    font-family: var(--font-brand-impact);
    font-size: clamp(1.25rem, 3vw, 2.2rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text);
    line-height: 1.2;
    margin-top: 0.25rem;
    opacity: 0;
    animation: fadeInUp 1s var(--ease-out-expo) 0.5s forwards;
  }

  .hero__tagline {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeInUp 0.8s var(--ease-out-expo) 0.7s forwards;
  }

  .hero__description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 34ch;
    margin-bottom: 2rem;
    line-height: 1.7;
    opacity: 0;
    animation: fadeInUp 0.8s var(--ease-out-expo) 0.85s forwards;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeInUp 0.8s var(--ease-out-expo) 1s forwards;
  }

  .hero__meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeInUp 0.8s var(--ease-out-expo) 1.1s forwards;
  }

  .hero__open-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #34D399;
    background: rgba(52, 211, 153, 0.1);
    border: 1px solid rgba(52, 211, 153, 0.2);
    padding: 0.35rem 0.75rem;
    border-radius: 2rem;
  }

  .hero__open-badge.closed {
    color: var(--color-text-dim);
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--color-border);
  }

  .hero__open-badge.closed .hero__open-dot {
    background: var(--color-text-dim);
    box-shadow: none;
  }

  .hero__open-dot {
    width: 6px;
    height: 6px;
    background: #34D399;
    border-radius: 50%;
    box-shadow: 0 0 6px rgba(52, 211, 153, 0.5);
  }

  .hero__address {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .hero__address:hover {
    color: var(--color-accent);
  }

  .hero__address svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    opacity: 0;
    animation: fadeIn 1s var(--ease-out-expo) 1.5s forwards;
  }

  .hero__scroll-line {
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(180deg, var(--color-accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding-top: 2rem;
    }

    .hero__video-wrap {
      aspect-ratio: 16 / 9;
    }

    .hero__actions {
      flex-direction: column;
    }
  }
</style>

<script>
  const badge = document.getElementById('hero-open-badge');
  if (badge) {
    const now = new Date();
    const day = now.getDay();
    const hour = now.getHours();
    const isOpen =
      (day >= 1 && day <= 5 && hour >= 9 && hour < 17) ||
      (day === 6 && hour >= 9 && hour < 15);
    if (!isOpen) {
      badge.classList.add('closed');
      const text = badge.querySelector('.hero__open-text');
      if (text) text.textContent = 'Closed';
    }
  }
</script>
