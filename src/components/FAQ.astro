---
const faqs = [
  {
    question: 'How long does window tinting take?',
    answer: 'Most cars are done in 30 to 40 minutes. Larger vehicles like SUVs or trucks may take up to an hour. Residential and commercial jobs depend on the number of windows.',
  },
  {
    question: "What are California's window tinting laws?",
    answer: "California allows any darkness on rear and back side windows. Front side windows must allow more than 70% of light through. The windshield can only have tint on the top 4 inches. We carry California-legal options and can walk you through what's allowed.",
  },
  {
    question: 'What brands of film do you carry?',
    answer: "We're an authorized dealer for LLumar, SunTek, and Maxpro. All three are professional-grade films with excellent heat rejection, UV blocking, and clarity. We'll help you pick the right film for your needs and budget.",
  },
  {
    question: 'Do you offer mobile service?',
    answer: 'Yes. We can come to your home, office, or dealership lot. Same professional install, same films, same quality. Call us to schedule a mobile appointment.',
  },
  {
    question: 'Can I roll my windows down after tinting?',
    answer: "Wait at least 3 to 5 days before rolling your windows down. The film needs time to cure and bond to the glass. You may notice small water bubbles during this period. They'll disappear as the film dries.",
  },
  {
    question: 'How do I care for my new tint?',
    answer: 'After the curing period, clean your windows with a soft cloth and ammonia-free cleaner. Avoid abrasive pads or harsh chemicals. The film is durable but treating it right keeps it looking sharp for years.',
  },
  {
    question: 'Do you tint specialty vehicles?',
    answer: "Yes. We work on RVs, tractors, boats, heavy equipment, and anything else with windows. We've handled John Deere combines, commercial fleet vehicles, and classic cars. If it has glass, we can tint it.",
  },
  {
    question: 'Are you licensed?',
    answer: "Yes. Pacific Window Tint holds California Contractor License #896816. We've been a licensed, insured business in Stockton since 2007.",
  },
];
---

<section class="faq section" id="faq">
  <div class="container container--narrow">
    <div class="faq__header">
      <span class="section-label">Questions</span>
      <h2 class="section-title">Frequently Asked</h2>
    </div>

    <div class="faq__list">
      {faqs.map((faq, i) => (
        <details class="faq__item" data-faq={i}>
          <summary class="faq__question">
            <span>{faq.question}</span>
            <svg class="faq__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq__answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__header { text-align: center; margin-bottom: clamp(2.5rem, 5vh, 4rem); }
  .faq__list { display: flex; flex-direction: column; }
  .faq__item { border-bottom: 1px solid var(--color-border); }
  .faq__item:first-child { border-top: 1px solid var(--color-border); }
  .faq__question {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.25rem 0; font-family: var(--font-display); font-size: var(--text-base);
    font-weight: 600; cursor: pointer; list-style: none; transition: color var(--transition-fast);
  }
  .faq__question::-webkit-details-marker { display: none; }
  .faq__question:hover { color: var(--color-accent); }
  .faq__chevron { flex-shrink: 0; color: var(--color-text-dim); transition: transform var(--transition-base); }
  .faq__item[open] .faq__chevron { transform: rotate(180deg); color: var(--color-accent); }
  .faq__answer { padding-bottom: 1.25rem; }
  .faq__answer p { font-size: var(--text-base); color: var(--color-text-muted); line-height: 1.7; max-width: 60ch; }
</style>
