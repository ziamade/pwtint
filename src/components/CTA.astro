---
import { site } from '../data/site';
---

<section class="cta-section section" id="contact">
  <div class="cta__glow" aria-hidden="true"></div>
  <div class="container container--narrow">
    <div class="cta__content">
      <span class="section-label">Ready?</span>
      <h2 class="cta__heading">
        We'll come to you<br />
        <span class="text-accent">tomorrow.</span>
      </h2>
      <p class="cta__text">
        Call or text to book. Most appointments scheduled within 24 hours.
      </p>

      <a href={`tel:${site.phoneTel}`} class="cta__phone">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {site.phone}
      </a>

      <a href={`mailto:${site.email}`} class="cta__email">
        {site.email}
      </a>

      <div class="cta__details">
        <div class="cta__detail">
          <h3 class="cta__detail-title">Hours</h3>
          <p>Mon-Fri: 9 AM - 5 PM</p>
          <p>Saturday: 9 AM - 3 PM</p>
          <p class="text-muted">Closed Sunday</p>
        </div>
        <div class="cta__detail">
          <h3 class="cta__detail-title">Location</h3>
          <p>{site.address}</p>
          <p>{site.city}, {site.state} {site.zip}</p>
          <a href={site.mapUrl} target="_blank" rel="noopener" class="cta__map-link">
            Get Directions
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
        </div>
      </div>

      <div class="cta__films">
        <span class="cta__films-label">Authorized dealer:</span>
        {site.films.map((film) => (
          <span class="cta__film-badge">{film}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    text-align: center;
    overflow: hidden;
  }

  .cta__glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 50%;
    height: 60%;
    background: radial-gradient(
      ellipse at center,
      var(--color-accent-glow) 0%,
      transparent 70%
    );
    opacity: 0.2;
    pointer-events: none;
  }

  .cta__content {
    position: relative;
    z-index: 2;
  }

  .cta__heading {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .cta__text {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .cta__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    transition: all var(--transition-base);
  }

  .cta__phone:hover {
    text-shadow: 0 0 20px var(--color-accent-glow);
    transform: scale(1.02);
  }

  .cta__email {
    display: block;
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: 3rem;
    transition: color var(--transition-fast);
  }

  .cta__email:hover {
    color: var(--color-accent);
  }

  .cta__details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    text-align: left;
    max-width: 28rem;
    margin-inline: auto;
    margin-bottom: 3rem;
    padding: 2rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .cta__detail-title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .cta__detail p {
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .cta__map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: var(--text-sm);
    color: var(--color-accent);
    margin-top: 0.5rem;
    transition: opacity var(--transition-fast);
  }

  .cta__map-link:hover {
    opacity: 0.8;
  }

  .cta__films {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta__films-label {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .cta__film-badge {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 0.375rem 0.75rem;
    background: var(--color-bg-glass);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .cta__details {
      grid-template-columns: 1fr;
    }
  }
</style>
