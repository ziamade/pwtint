---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import semaImg from '../assets/images/IMG_9184.jpg';
import lobbyImg from '../assets/images/IMG_6700.JPEG';
---

<section class="about section" id="about">
  <div class="container">
    <div class="about__grid">
      <div class="about__content">
        <span class="section-label">About Us</span>
        <h2 class="section-title">
          <span class="brandname"><span class="brandname-p">Pacific</span> <span class="brandname-wt">Window Tint</span></span>
        </h2>
        <p class="about__text">
          Dana Ota started Pacific Window Tint in 2007. What began as a one-man operation
          on Davis Road has grown into one of Stockton's most trusted tint shops, with
          a fully equipped facility and a mobile unit that serves the entire San Joaquin Valley.
        </p>
        <p class="about__text">
          We're an authorized dealer for LLumar, SunTek, and Maxpro. We use computer-cut
          patterns for every vehicle, so the film fits perfectly without cutting on your glass.
          Dana still personally handles installs and stays current with the industry,
          attending SEMA and training on the latest films and techniques.
        </p>
        <p class="about__text">
          Whether it's a daily driver, a classic Mustang, a John Deere combine, or a
          commercial storefront, we've done it. California Contractor License {site.license}.
        </p>
      </div>

      <div class="about__images">
        <div class="about__image-wrap about__image-wrap--main">
          <Image
            src={lobbyImg}
            alt="Pacific Window Tint reception and front desk"
            class="about__image"
            widths={[300, 500]}
            sizes="(max-width: 768px) 100vw, 40vw"
            format="webp"
          />
        </div>
        <div class="about__image-wrap about__image-wrap--inset">
          <Image
            src={semaImg}
            alt="Owner Dana Ota at the SEMA automotive trade show"
            class="about__image"
            widths={[200, 350]}
            sizes="(max-width: 768px) 50vw, 25vw"
            format="webp"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
  }

  .about__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-top: 1.25rem;
  }

  .about__text:first-of-type {
    margin-top: 1.5rem;
  }

  .about__images {
    position: relative;
  }

  .about__image-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .about__image-wrap--main {
    aspect-ratio: 4 / 3;
  }

  .about__image-wrap--inset {
    position: absolute;
    bottom: -1.5rem;
    right: -1rem;
    width: 45%;
    aspect-ratio: 1;
    border: 3px solid var(--color-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .about__image {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
    }

    .about__image-wrap--inset {
      bottom: -1rem;
      right: 0;
      width: 40%;
    }
  }
</style>
