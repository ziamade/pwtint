---
import site from '../data/site.json';
---

<section class="about-section" id="about">
  <div class="about-inner">
    <h2>About <span class="pacific-styled">Pacific</span> Window Tint</h2>
    <p>Dana started Pacific Window Tint in {site.founded} with one goal: give Stockton a tint shop that does it right. No shortcuts, no cheap film, no excuses. Every car, home, and commercial project gets the same attention to detail.</p>
    <p>We carry a full range of professional-grade films, from basic dyed tint to premium ceramic. We'll walk you through the options, help you pick the right film for your needs and budget, and get it installed clean the first time.</p>
    <p>Fully licensed (CA {site.license}) and insured. We offer lifetime warranty coverage on select premium installations. Ask about warranty options for your project.</p>
  </div>
</section>

<style>
  .about-section {
    padding: var(--section-padding);
    background: var(--navy);
    position: relative;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--white-10), transparent);
  }

  .about-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .about-inner h2 {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .pacific-styled {
    font-family: var(--font-script);
    color: var(--electric);
    font-weight: 700;
  }

  .about-inner p {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-inner p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .about-section {
      padding: 3rem 1rem;
    }

    .about-inner h2 {
      font-size: 1.8rem;
    }

    .about-inner p {
      font-size: 0.95rem;
    }
  }
</style>
