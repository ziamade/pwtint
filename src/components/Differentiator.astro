---
import { Image } from 'astro:assets';
import signImg from '../assets/images/IMG_6706.jpg';
import truckImg from '../assets/images/img_trailer.JPG';
---

<section class="diff section" id="differentiator">
  <div class="container">
    <div class="diff__header">
      <span class="section-label">Your Choice</span>
      <h2 class="section-title">
        Visit our shop. <span class="text-accent">Or we come to you.</span>
      </h2>
      <p class="section-subtitle">
        Stop by our Davis Road location for a full in-shop experience, or skip the trip.
        Our mobile unit comes to your driveway, your office, your dealership. Same quality, same films. Your call.
      </p>
    </div>

    <div class="diff__panels">
      <div class="diff__panel diff__panel--shop">
        <div class="diff__panel-image-wrap">
          <Image
            src={signImg}
            alt="Pacific Window Tint storefront sign - Est 2007, 8829 Davis Road"
            class="diff__panel-image"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            format="webp"
          />
          <div class="diff__panel-overlay"></div>
        </div>
        <div class="diff__panel-content">
          <h3 class="diff__panel-title">In-Shop Service</h3>
          <p class="diff__panel-text">
            Our fully equipped Davis Road location. Drop off in the morning, pick up the same day.
            Comfortable waiting area with Wi-Fi.
          </p>
        </div>
      </div>

      <div class="diff__panel-divider">
        <span class="diff__panel-or">or</span>
      </div>

      <div class="diff__panel diff__panel--mobile">
        <div class="diff__panel-image-wrap">
          <Image
            src={truckImg}
            alt="Pacific Window Tint mobile service truck"
            class="diff__panel-image"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            format="webp"
          />
          <div class="diff__panel-overlay"></div>
        </div>
        <div class="diff__panel-content">
          <h3 class="diff__panel-title">Mobile Service</h3>
          <p class="diff__panel-text">
            Can't make the trip? We pull up to your home, office, or dealership lot.
            Same professional install, wherever you are.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .diff__header {
    text-align: center;
    margin-bottom: clamp(3rem, 6vh, 5rem);
  }

  .diff__header .section-subtitle {
    margin-inline: auto;
    max-width: 50ch;
  }

  .diff__panels {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: stretch;
  }

  .diff__panel {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-base);
  }

  .diff__panel:hover {
    border-color: var(--color-border-accent);
  }

  .diff__panel-image-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .diff__panel-image {
    width: 100% !important;
    height: 100% !important;
    max-height: none !important;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .diff__panel:hover .diff__panel-image {
    transform: scale(1.03);
  }

  .diff__panel-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(10, 10, 10, 0.5) 100%);
  }

  .diff__panel-content {
    padding: 1.5rem 2rem 2rem;
  }

  .diff__panel-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .diff__panel-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .diff__panel-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: 1.5rem;
  }

  .diff__panel-or {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  @media (max-width: 768px) {
    .diff__panels {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .diff__panel-divider {
      padding-block: 0.5rem;
    }
  }
</style>
