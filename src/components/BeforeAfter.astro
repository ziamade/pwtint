---
import { Image } from 'astro:assets';
import beforeImg from '../assets/images/img_autobf.png';
import afterImg from '../assets/images/img_autotint.JPEG';
---

<section class="ba-section" id="gallery">
  <div class="ba-header container">
    <span class="section-label">The Transformation</span>
    <h2 class="section-title">See the Difference</h2>
    <p class="section-subtitle">Scroll to reveal the tint. This is what professional installation looks like.</p>
  </div>

  <div class="ba-viewport">
    <div class="ba-container">
      <Image
        src={beforeImg}
        alt="Vehicle before window tinting"
        class="ba-before"
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        format="webp"
      />
      <Image
        src={afterImg}
        alt="Vehicle after professional window tinting"
        class="ba-after"
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        format="webp"
      />

      <div class="ba-divider">
        <div class="ba-divider-line"></div>
        <div class="ba-divider-handle">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </div>
      </div>

      <div class="ba-label ba-label--before">Before</div>
      <div class="ba-label ba-label--after">After</div>
    </div>

    <div class="ba-hint" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      Keep scrolling
    </div>
  </div>
</section>

<style>
  .ba-section {
    position: relative;
  }

  .ba-header {
    padding-top: var(--section-py);
    padding-bottom: clamp(2rem, 4vh, 3rem);
  }

  .ba-viewport {
    position: relative;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
  }

  .ba-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ba-before,
  .ba-after {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-after {
    clip-path: inset(0 100% 0 0);
  }

  .ba-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0%;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .ba-divider-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent-glow), 0 0 24px var(--color-accent-glow);
  }

  .ba-divider-handle {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    width: 3rem;
    height: 3rem;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 50%;
    justify-content: center;
    box-shadow: 0 0 20px var(--color-accent-glow);
  }

  .ba-label {
    position: absolute;
    top: 1.5rem;
    z-index: 5;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
  }

  .ba-label--before {
    left: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    color: var(--color-text);
  }

  .ba-label--after {
    right: 1.5rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid var(--color-border-accent);
  }

  .ba-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    z-index: 5;
    animation: fadeIn 1s ease 1s forwards;
    opacity: 0;
  }

  .ba-hint svg {
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes scrollPulse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
</style>
