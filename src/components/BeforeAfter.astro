---
import { Image } from 'astro:assets';
import beforeImg from '../assets/images/img_autobf.png';
import afterImg from '../assets/images/img_autotint.JPEG';
---

<section class="ba-section" id="gallery">
  <div class="ba-header container">
    <span class="section-label">The Transformation</span>
    <h2 class="section-title">See the Difference</h2>
    <p class="section-subtitle">Drag the slider to reveal the tint.</p>
  </div>

  <div class="ba-viewport">
    <div class="ba-container" id="ba-container">
      <Image
        src={beforeImg}
        alt="Vehicle before window tinting"
        class="ba-before"
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        format="webp"
      />
      <div class="ba-after" id="ba-after">
        <Image
          src={afterImg}
          alt="Vehicle after professional window tinting"
          class="ba-after-img"
          widths={[640, 960, 1280, 1920]}
          sizes="100vw"
          format="webp"
        />
      </div>

      <div
        class="ba-divider"
        id="ba-divider"
        role="slider"
        tabindex="0"
        aria-label="Before and after comparison slider"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
      >
        <div class="ba-divider-line"></div>
        <div class="ba-divider-handle">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </div>
      </div>

      <div class="ba-label ba-label--before">Before</div>
      <div class="ba-label ba-label--after">After</div>
    </div>

    <div class="ba-hint" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      Drag to compare
    </div>
  </div>
</section>

<script>
  let ac: AbortController | null = null;

  function initBeforeAfter() {
    ac?.abort();
    ac = new AbortController();
    const { signal } = ac;

    const container = document.getElementById('ba-container');
    const afterEl = document.getElementById('ba-after');
    const divider = document.getElementById('ba-divider');
    if (!container || !afterEl || !divider) return;

    let isDragging = false;

    function updatePosition(clientX: number) {
      const rect = container!.getBoundingClientRect();
      const x = clientX - rect.left;
      const pct = Math.max(0, Math.min(100, (x / rect.width) * 100));

      afterEl!.style.clipPath = `inset(0 0 0 ${pct}%)`;
      divider!.style.left = `${pct}%`;
      divider!.setAttribute('aria-valuenow', String(Math.round(pct)));
    }

    function stopDrag() {
      isDragging = false;
      document.body.style.userSelect = '';
      document.body.style.cursor = '';
    }

    // Mouse events
    divider.addEventListener('mousedown', (e) => {
      e.preventDefault();
      isDragging = true;
      document.body.style.userSelect = 'none';
      document.body.style.cursor = 'col-resize';
    }, { signal });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      updatePosition(e.clientX);
    }, { signal });

    document.addEventListener('mouseup', stopDrag, { signal });

    // Touch events — touch-action: none on .ba-divider handles scroll prevention
    divider.addEventListener('touchstart', () => {
      isDragging = true;
    }, { passive: true, signal });

    document.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      updatePosition(e.touches[0].clientX);
    }, { passive: true, signal });

    document.addEventListener('touchend', stopDrag, { signal });

    // Click anywhere on container to jump
    container.addEventListener('click', (e) => {
      if (isDragging) return;
      updatePosition(e.clientX);
    }, { signal });

    // Keyboard support
    divider.addEventListener('keydown', (e) => {
      const currentPct = parseFloat(divider.getAttribute('aria-valuenow') || '50');
      let newPct = currentPct;

      if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') newPct -= 2;
      else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') newPct += 2;
      else if (e.key === 'Home') newPct = 0;
      else if (e.key === 'End') newPct = 100;
      else return;

      e.preventDefault();
      newPct = Math.max(0, Math.min(100, newPct));
      afterEl!.style.clipPath = `inset(0 0 0 ${newPct}%)`;
      divider.style.left = `${newPct}%`;
      divider.setAttribute('aria-valuenow', String(Math.round(newPct)));
    }, { signal });
  }

  initBeforeAfter();
  document.addEventListener('astro:after-swap', initBeforeAfter);
</script>

<style>
  .ba-section {
    position: relative;
  }

  .ba-header {
    padding-top: var(--section-py);
    padding-bottom: clamp(2rem, 4vh, 3rem);
  }

  .ba-viewport {
    position: relative;
    height: 80vh;
    height: 80dvh;
    overflow: hidden;
  }

  .ba-container {
    position: relative;
    width: 100%;
    height: 100%;
    cursor: col-resize;
  }

  .ba-before {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-after {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    clip-path: inset(0 0 0 50%);
  }

  .ba-after-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: col-resize;
    touch-action: none;
  }

  .ba-divider-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent-glow), 0 0 24px var(--color-accent-glow);
  }

  .ba-divider-handle {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    width: 3rem;
    height: 3rem;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 50%;
    justify-content: center;
    box-shadow: 0 0 20px var(--color-accent-glow);
    transition: transform 0.2s ease;
  }

  .ba-divider:hover .ba-divider-handle,
  .ba-divider:focus-visible .ba-divider-handle {
    transform: scale(1.15);
  }

  .ba-divider:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .ba-label {
    position: absolute;
    top: 1.5rem;
    z-index: 5;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
  }

  .ba-label--before {
    left: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    color: var(--color-text);
  }

  .ba-label--after {
    right: 1.5rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid var(--color-border-accent);
  }

  .ba-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    z-index: 5;
    animation: fadeIn 1s ease 1s forwards;
    opacity: 0;
    pointer-events: none;
  }

  .ba-hint svg {
    animation: swipeHint 2s ease-in-out infinite;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes swipeHint {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(6px); }
  }
</style>
