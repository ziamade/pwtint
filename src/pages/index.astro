---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Differentiator from '../components/Differentiator.astro';
import Services from '../components/Services.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Gallery from '../components/Gallery.astro';
import Reviews from '../components/Reviews.astro';
import About from '../components/About.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />

  <main>
    <Hero />
    <TrustBar />
    <Differentiator />
    <div class="section--elevated">
      <Services />
    </div>
    <BeforeAfter />
    <div class="section--textured">
      <Gallery />
    </div>
    <Reviews />
    <About />
    <div class="section--elevated">
      <FAQ />
    </div>
    <ContactForm />
  </main>

  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  if (!prefersReducedMotion) {
    // Lenis smooth scroll
    const lenis = new Lenis({
      lerp: 0.1,
      duration: 1.2,
      wheelMultiplier: 1.0,
      touchMultiplier: 2.0,
    });

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    // Nav: hide on scroll down, show on scroll up
    const nav = document.getElementById('nav');
    let lastScroll = 0;

    ScrollTrigger.create({
      onUpdate: (self) => {
        if (!nav) return;
        const currentScroll = self.scroll();
        nav.classList.toggle('scrolled', currentScroll > 80);
        if (currentScroll > 300) {
          if (currentScroll > lastScroll && currentScroll - lastScroll > 5) {
            nav.classList.add('hidden');
          } else if (lastScroll > currentScroll && lastScroll - currentScroll > 5) {
            nav.classList.remove('hidden');
          }
        } else {
          nav.classList.remove('hidden');
        }
        lastScroll = currentScroll;
      },
    });

    // Trust bar: fade in
    gsap.from('.trust__item', {
      y: 20, opacity: 0, duration: 0.5, stagger: 0.08, ease: 'power3.out',
      scrollTrigger: { trigger: '.trust', start: 'top 90%' },
    });

    // Differentiator: panels slide in from opposite sides
    const shopPanel = document.querySelector('.diff__panel--shop');
    const mobilePanel = document.querySelector('.diff__panel--mobile');
    if (shopPanel) {
      gsap.from(shopPanel, {
        x: -80, opacity: 0, duration: 1, ease: 'power3.out',
        scrollTrigger: { trigger: '.diff__panels', start: 'top 80%' },
      });
    }
    if (mobilePanel) {
      gsap.from(mobilePanel, {
        x: 80, opacity: 0, duration: 1, ease: 'power3.out',
        scrollTrigger: { trigger: '.diff__panels', start: 'top 80%' },
      });
    }

    // Services: staggered card entrance
    const serviceCards = gsap.utils.toArray('.service-card');
    if (serviceCards.length) {
      gsap.set(serviceCards, { y: 60, opacity: 0 });
      ScrollTrigger.create({
        trigger: '.services__grid',
        start: 'top 85%',
        onEnter: () => {
          gsap.to(serviceCards, {
            y: 0, opacity: 1, duration: 0.7, stagger: 0.1, ease: 'power3.out',
          });
        },
        once: true,
      });
    }

    // Before/After is now a self-contained drag slider (no GSAP needed)

    // Gallery: staggered entrance
    gsap.from('.gallery__item', {
      y: 40, opacity: 0, duration: 0.5, stagger: 0.08, ease: 'power3.out',
      scrollTrigger: { trigger: '.gallery__grid', start: 'top 85%' },
    });

    // Reviews: staggered card entrance
    gsap.from('.review-card', {
      y: 50, opacity: 0, duration: 0.6, stagger: 0.12, ease: 'power3.out',
      scrollTrigger: { trigger: '.reviews__grid', start: 'top 80%' },
    });

    // Contact form: slide in
    const contactInfo = document.querySelector('.contact-form__info');
    const contactFormEl = document.querySelector('.contact-form__form');
    if (contactInfo) {
      gsap.from(contactInfo, {
        x: -40, opacity: 0, duration: 0.8, ease: 'power3.out',
        scrollTrigger: { trigger: '.contact-form', start: 'top 75%' },
      });
    }
    if (contactFormEl) {
      gsap.from(contactFormEl, {
        x: 40, opacity: 0, duration: 0.8, ease: 'power3.out',
        scrollTrigger: { trigger: '.contact-form', start: 'top 75%' },
      });
    }
  }
</script>
