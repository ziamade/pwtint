---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} | ${site.city}, ${site.state}`,
  description = `Professional mobile window tinting in ${site.city}, ${site.state} since ${site.foundingYear}. Automotive, residential, and commercial tinting. We come to you. Call ${site.phone}.`,
} = Astro.props;

const ogImage = new URL('/og-image.jpg', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AutoRepair",
      "name": site.name,
      "telephone": site.phone,
      "email": site.email,
      "url": site.domain,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": site.address,
        "addressLocality": site.city,
        "addressRegion": site.state,
        "postalCode": site.zip,
        "addressCountry": "US"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": site.rating,
        "reviewCount": site.reviewCount,
        "bestRating": 5
      },
      "openingHoursSpecification": site.hours
        .filter(h => h.open)
        .map(h => ({
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": h.day,
          "opens": h.open,
          "closes": h.close
        })),
      "foundingDate": String(site.foundingYear),
      "priceRange": "$$"
    })} />
  </head>
  <body>
    <div class="zm-top">
      <span class="zm-top__icon">&#9432;</span>
      Preview site built by ZiaMade. Content may not be accurate. Not owned or endorsed by the business.
    </div>

    <slot />

    <div class="zm-bottom">
      <img class="zm-bottom__logo" src="data:image/webp;base64," alt="ZiaMade" />
      <div class="zm-bottom__text">
        <div class="zm-bottom__title">This could be your live website</div>
        <div class="zm-bottom__sub">Built by Alex. $29/mo. No contracts.</div>
      </div>
      <div class="zm-bottom__buttons">
        <a href="https://ziamade.com/faq" class="zm-btn zm-btn--ghost">Questions?</a>
        <a href="https://ziamade.com/go/pwtint" class="zm-btn zm-btn--primary">Make It Live</a>
      </div>
    </div>

    <style is:global>
      .zm-top{all:initial!important;display:block!important;position:sticky!important;top:0!important;z-index:99999!important;background:#1a1a1a!important;border-bottom:1px solid rgba(255,255,255,0.06)!important;padding:7px 16px!important;font-family:-apple-system,system-ui,sans-serif!important;font-size:11px!important;color:#777!important;text-align:center!important;line-height:1.4!important;box-sizing:border-box!important}
      .zm-top__icon{all:initial!important;color:#666!important;margin-right:6px!important;font-size:11px!important}
      .zm-bottom{all:initial!important;display:flex!important;align-items:center!important;gap:14px!important;flex-wrap:wrap!important;position:sticky!important;bottom:0!important;z-index:99999!important;background:rgba(0,0,0,0.92)!important;backdrop-filter:blur(12px)!important;-webkit-backdrop-filter:blur(12px)!important;border-top:1px solid rgba(255,255,255,0.1)!important;padding:10px 20px!important;font-family:-apple-system,system-ui,sans-serif!important;box-sizing:border-box!important}
      .zm-bottom__logo{all:initial!important;display:block!important;width:auto!important;height:22px!important;flex-shrink:0!important;object-fit:contain!important;overflow:clip!important}
      .zm-bottom__text{all:initial!important;display:block!important;flex:1!important;min-width:140px!important}
      .zm-bottom__title{all:initial!important;display:block!important;font-size:13px!important;color:#fff!important;font-weight:600!important}
      .zm-bottom__sub{all:initial!important;display:block!important;font-size:11px!important;color:#999!important}
      .zm-bottom__buttons{all:initial!important;display:flex!important;gap:8px!important;flex-shrink:0!important}
      .zm-btn{all:initial!important;display:inline-block!important;padding:8px 16px!important;border-radius:6px!important;font-size:12px!important;text-decoration:none!important;cursor:pointer!important;box-sizing:border-box!important}
      .zm-btn--ghost{color:#ccc!important;font-weight:500!important;border:1px solid rgba(255,255,255,0.2)!important;background:transparent!important}
      .zm-btn--primary{color:#111!important;font-weight:700!important;background:#e8c547!important;border:none!important}
      @media(max-width:640px){.zm-bottom{flex-direction:column!important;padding:10px 14px!important;gap:8px!important}.zm-bottom__buttons{width:100%!important}.zm-btn{flex:1!important;text-align:center!important}}
    </style>
  </body>
</html>
